<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.learn.mall.product.mapper.SpuDetailMapper">

    <select id="getBySpuId" resultType="com.learn.mall.product.model.SpuDetail">
        select spu_id, detail from spu_detail where spu_id = #{spuId}
    </select>

    <insert id="save">
        insert into spu_detail (spu_id, detail) values (#{spuId}, #{detail})
    </insert>

    <update id="update">
        update spu_detail set detail = #{detail} where spu_id = #{spuId}
    </update>
</mapper>
